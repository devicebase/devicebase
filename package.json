{
  "name": "devicebase",
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@11.1.2",
  "description": "Devicebase SDK & CLI for remote Android, HarmonyOS, and iOS device control via HTTP API",
  "author": "Devicebase Team (https://devicebase.cn)",
  "license": "MIT",
  "homepage": "https://github.com/devicebase/devicebase#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devicebase/devicebase.git"
  },
  "bugs": {
    "url": "https://github.com/devicebase/devicebase/issues"
  },
  "keywords": [
    "devicebase",
    "device-automation",
    "android",
    "ios",
    "harmonyos",
    "remote-control",
    "testing",
    "cli"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/devicebase.es.js",
      "require": "./dist/devicebase.umd.js",
      "default": "./dist/devicebase.es.js"
    }
  },
  "main": "./dist/devicebase.umd.js",
  "module": "./dist/devicebase.es.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "devicebase": "./dist/bin/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite-node examples/basic-usage.ts",
    "dev:bin": "vite-node src/cli/index.ts",
    "build": "vite build && tsc -p tsconfig.lib.json",
    "build:bin": "vite build --config vite.config.bin.ts",
    "build:all": "pnpm build && pnpm build:bin",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "version": "auto-changelog-plus -p && git add CHANGELOG.md",
    "postversion": "git push --tags && git push",
    "prepublishOnly": "pnpm build:all"
  },
  "auto-changelog-plus": {
    "authorMap": {
      "Richie": "RichieMess",
      "Cell": "Lruihao"
    }
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^22.0.0",
    "auto-changelog-plus": "^1.3.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-node": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
